# Supabase project (Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser. Used by the Hotmart webhook to
# write purchases with elevated privileges (bypassing RLS).
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL, used to build the magic-link redirect and Open Graph tags.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI (Fase 5 content production only -- not used by the running app).
# Used by `npm run generate:images` to batch-generate the 100 recipe images
# from content/image-prompts.json. Needs billing enabled on the account.
OPENAI_API_KEY=

# Public product page on Hotmart. Leave empty until the product is actually
# published there -- the landing page shows a non-clickable "coming soon"
# state instead of a placeholder/fake link when this is unset.
NEXT_PUBLIC_HOTMART_URL=

# Hotmart webhook. HOTMART_HOTTOK is the token Hotmart sends back on every
# webhook call so we can verify the request actually came from Hotmart --
# see https://developers.hotmart.com (confirm the exact header/field name
# for your product's webhook version before going live; do not assume).
HOTMART_HOTTOK=
